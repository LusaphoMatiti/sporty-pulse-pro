generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"

}

datasource db {
  provider  = "postgresql"

}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  ATHLETE
  COACH
  ADMIN
}

enum Plan {
  FREE
  EQUIPMENT
  PRO
}

enum EquipmentSource {
  PURCHASED
  DECLARED
  BODYWEIGHT
}

enum MuscleGroup {
  UPPER
  LOWER
  CORE
  FULLBODY
}

enum PlanTier {
  FREE
  EQUIPMENT
  PRO
}

enum UserLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum InstanceStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

// ─────────────────────────────────────────────
// AUTH LAYER
// ─────────────────────────────────────────────

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  name               String?
  password           String?
  emailVerified      DateTime?
  image              String?
  role               Role      @default(ATHLETE)
  lastLoginAt        DateTime?
  onboardingComplete Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  isNewUser         Boolean   @default(true)

  accounts      Account[]
  sessions      NextAuthSession[]
  subscription  Subscription?
  userEquipment UserEquipment[]
  instances     PlanInstance[]
  workoutLogs   WorkoutLog[]

  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model NextAuthSession {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────
// EQUIPMENT
// ─────────────────────────────────────────────

model Equipment {
  id        String @id @default(uuid())
  name      String @unique
  category  String // "fullbody" | "upper" | "lower" | "core"

  userEquipment UserEquipment[]
  exercises     Exercise[]
  workoutPlans  WorkoutPlan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("equipment")
}

// ─────────────────────────────────────────────
// EXERCISE LIBRARY
// ─────────────────────────────────────────────

model Exercise {
  id            String  @id @default(uuid())
  name          String  @unique
  description   String?
  youtubeUrl    String?
  musclesWorked String[] // ["glutes", "hamstrings", "quads"]
  muscleGroup   MuscleGroup

  equipmentId String?
  equipment   Equipment? @relation(fields: [equipmentId], references: [id])

  plannedExercises PlannedExercise[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("exercises")
}

// ─────────────────────────────────────────────
// WORKOUT PLAN
// ─────────────────────────────────────────────

model WorkoutPlan {
  id              String      @id @default(cuid())
  name            String      @unique
  description     String
  muscleGroup     MuscleGroup
  durationWeeks   Int
  sessionsPerWeek Int
  tier            PlanTier    @default(FREE)

  equipmentId String?
  equipment   Equipment? @relation(fields: [equipmentId], references: [id])

  plannedSessions PlannedSession[]
  instances       PlanInstance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("workout_plans")
}

// ─────────────────────────────────────────────
// PLANNED SESSION
// ─────────────────────────────────────────────

model PlannedSession {
  id            String @id @default(cuid())
  sessionNumber Int
  focus         String

  planId String
  plan   WorkoutPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  plannedExercises PlannedExercise[]

  @@unique([planId, sessionNumber])
  @@map("planned_sessions")
}

// ─────────────────────────────────────────────
// PLANNED EXERCISE
// ─────────────────────────────────────────────

model PlannedExercise {
  id    String @id @default(cuid())
  order Int

  sessionId String
  session   PlannedSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id])

  beginnerSets     Int
  beginnerReps     Int
  intermediateSets Int
  intermediateReps Int
  advancedSets     Int
  advancedReps     Int
  restSeconds      Int

  loggedSets WorkoutLog[]

  @@unique([sessionId, order])
  @@map("planned_exercises")
}

// ─────────────────────────────────────────────
// PLAN INSTANCE
// ─────────────────────────────────────────────

model PlanInstance {
  id             String         @id @default(cuid())
  level          UserLevel
  status         InstanceStatus @default(ACTIVE)
  currentSession Int            @default(1)
  startedAt      DateTime       @default(now())
  completedAt    DateTime?
  sessionDraft   Json?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  planId String
  plan   WorkoutPlan @relation(fields: [planId], references: [id])

  workoutLogs WorkoutLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("plan_instances")
}

// ─────────────────────────────────────────────
// WORKOUT LOG
// ─────────────────────────────────────────────

model WorkoutLog {
  id            String   @id @default(cuid())
  sessionNumber Int
  completedAt   DateTime @default(now())

  weightKg   Float?
  actualReps Int?
  actualSets Int?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  instanceId String
  instance   PlanInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  plannedExerciseId String
  plannedExercise   PlannedExercise @relation(fields: [plannedExerciseId], references: [id])

  createdAt DateTime @default(now())

  @@map("workout_logs")
}

// ─────────────────────────────────────────────
// SUBSCRIPTION
// ─────────────────────────────────────────────

model Subscription {
  id        String   @id @default(uuid())
  plan      Plan     @default(FREE)
  status    String
  source    String?
  startedAt DateTime @default(now())
  expiresAt DateTime?

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ─────────────────────────────────────────────
// USER EQUIPMENT
// ─────────────────────────────────────────────

model UserEquipment {
  id      String          @id @default(uuid())
  source  EquipmentSource
  addedAt DateTime        @default(now())
  trialExpiresAt DateTime? // only set when source = DECLARED

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id])

  @@map("user_equipment")
}
